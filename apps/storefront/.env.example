# ─── Sanity CMS ─────────────────────────────────────────────────────────────
# Dapatkan dari sanity.io/manage → project settings
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Read/write token — diperlukan untuk menyimpan pesanan ke Sanity
# Settings → API → Tokens → Add Editor token
SANITY_API_TOKEN=

# ─── Medusa Commerce Backend ─────────────────────────────────────────────────
# URL Medusa yang sudah di-deploy (Railway, Render, dll)
# Contoh: https://your-medusa.up.railway.app
NEXT_PUBLIC_MEDUSA_URL=

# ─── Midtrans Payment ────────────────────────────────────────────────────────
# Dapatkan dari dashboard.midtrans.com → Settings → Access Keys
# Gunakan Sandbox key untuk testing, Production key untuk live
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=
MIDTRANS_SERVER_KEY=

# ─── RajaOngkir Shipping ─────────────────────────────────────────────────────
# Dapatkan dari rajaongkir.com → API key (tier Starter/Basic)
RAJAONGKIR_API_KEY=

# ID kecamatan asal pengiriman (RajaOngkir district ID)
# Cari ID di: rajaongkir.com/api/subdistrict
ORIGIN_DISTRICT_ID=

# ─── Fonnte WhatsApp Notification ────────────────────────────────────────────
# Dapatkan dari fonnte.com → token device WhatsApp kamu
FONNTE_TOKEN=

# ─── Site URL ────────────────────────────────────────────────────────────────
# URL produksi — dipakai untuk OG image dan sitemap
# Contoh: https://draven.store
NEXT_PUBLIC_SITE_URL=https://draven.store
